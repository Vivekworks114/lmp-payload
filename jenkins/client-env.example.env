# Example per-tenant client build env (dotenv)
# Copy to one of:
#   Jenkins Secret file credential id: astropayload-site-env-<tenant_slug>
#   Agent file: $JENKINS_HOME/astropayload-client-env/<tenant_slug>.env
#
# Never commit real secrets. Values are written to the client checkout as .env
# during tenant-deploy (Astro/Vite loads them at build time).

PUBLIC_HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=
WEB3FORMS_API_KEY=
