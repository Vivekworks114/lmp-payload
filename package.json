{
  "name": "astropayload",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "payload": "pnpm --filter @astropayload/payload run",
    "payload:dev": "pnpm --filter @astropayload/payload run dev",
    "payload:build": "pnpm --filter @astropayload/payload run build",
    "payload:start": "pnpm --filter @astropayload/payload run start",
    "payload:types": "pnpm --filter @astropayload/payload run generate:types",
    "tenant-cli": "pnpm --filter @astropayload/tenant-cli exec tsx src/index.ts",
    "site": "pnpm --filter",
    "keukenfaqs:dev": "pnpm --filter @astropayload/site-keukenfaqs run dev",
    "keukenfaqs:build": "pnpm --filter @astropayload/site-keukenfaqs run build",
    "keukenfaqs:preview": "pnpm --filter @astropayload/site-keukenfaqs run preview",
    "keukenfaqs:sync": "pnpm --filter @astropayload/site-keukenfaqs run sync:content",
    "keukenfaqs:deploy": "pnpm --filter @astropayload/site-keukenfaqs run deploy"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
