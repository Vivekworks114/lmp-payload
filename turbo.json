{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": [
    "NODE_ENV",
    "PAYLOAD_URL",
    "PAYLOAD_API_KEY",
    "PAYLOAD_SECRET",
    "DATABASE_URI",
    "R2_BUCKET",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_PUBLIC_URL",
    "TENANT",
    "WEBHOOK_TOKEN",
    "GITHUB_TOKEN",
    "CLOUDFLARE_API_TOKEN",
    "CLOUDFLARE_ACCOUNT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "sync:content"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "sync:content": {
      "cache": false,
      "outputs": ["src/content/**", "src/data/**", "tenant.config.json"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
