# Payload
# IMPORTANT: Do NOT copy this placeholder value into .env. Generate a fresh
# random secret per environment:
#   openssl rand -hex 32
# Treat it like a password — never commit, never share, rotate yearly or on
# suspected leak. Changing it invalidates all existing sessions (everyone
# has to log in again), so coordinate before rotating in production.
PAYLOAD_SECRET=replace-with-output-of-openssl-rand-hex-32

# MUST exactly match the URL you type in your browser to reach the admin.
# In production behind nginx/cloudflare, this is the public HTTPS URL, NOT
# http://localhost:3000.
#   Local dev:   http://localhost:3000
#   Production:  https://cms.yourdomain.com
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: comma-separated extra origins allowed to send auth cookies
# (CORS + CSRF). Use this if the admin is reachable from multiple URLs
# (e.g. apex + www, or staging + prod).
# PAYLOAD_ALLOWED_ORIGINS=https://www.cms.yourdomain.com,https://staging.cms.yourdomain.com

# Optional: force the auth cookie's `Secure` flag.
#   - Unset (default)   → secure only when PAYLOAD_PUBLIC_SERVER_URL starts with https://.
#   - "false"           → never secure. Use when running over plain HTTP
#                         (http://your-ip:3000) before you've set up SSL.
#   - "true"            → always secure. Forces HTTPS-only cookies.
# WARNING: plain HTTP transmits your admin password in clear text. Use
# PAYLOAD_COOKIE_SECURE=false only on a private network or for short-lived
# testing, then move to HTTPS as soon as possible.
# PAYLOAD_COOKIE_SECURE=false

# Optional: name shown in authenticator apps when users set up 2FA (default: astropayload).
# PAYLOAD_TOTP_ISSUER=astropayload

# Debug logging (pm2 logs / docker stdout). Use on production while diagnosing saves/deletes.
# PAYLOAD_DEBUG_API=1
# PAYLOAD_DEBUG_AUTH=1  (legacy alias — also enables API logs)

# Optional — stabilizes admin Save/Delete across `next build` + PM2 restarts.
# MUST be base64 (Next.js runs atob() then AES-GCM). Decoded length = 16, 24, or 32 bytes.
#   CORRECT:  openssl rand -base64 32    → paste output below (≈44 chars)
#   WRONG:    openssl rand -hex 32       → causes "Invalid key length" on /admin
#   WRONG:    reusing PAYLOAD_SECRET     → hex, not base64
# Set BEFORE `pnpm build`, then: rm -rf .next && pnpm build && pm2 restart
# To disable: remove this line entirely and rebuild (admin works; hard-refresh after deploy).
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Postgres (Neon serverless recommended in prod)
DATABASE_URI=postgres://payload:payload@localhost:5432/astropayload

# Cloudflare R2 (S3-compatible) — required for Media uploads in production
# 1. Create bucket (e.g. astropayload-media)
# 2. Enable public access: R2.dev subdomain OR custom domain (e.g. media.yourdomain.com)
# 3. Create R2 API token (Object Read & Write on this bucket)
# 4. Set R2_PUBLIC_URL to the PUBLIC URL (not the S3 API endpoint)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=astropayload-media
# Public CDN URL — heroImage / featuredImage / ogImage links use this on sync & in admin
R2_PUBLIC_URL=https://media.example.com

# Webhook (Payload -> CI)
WEBHOOK_URL=https://webhook.example.com/payload
WEBHOOK_TOKEN=replace-with-shared-secret

# GitHub — used by:
#   1. The webhook receiver (apps/webhook), which dispatches tenant-deploy.yml
#      when content changes in Payload.
#   2. The Tenant admin buttons (Scaffold tenant code / Deploy now), which
#      dispatch tenant-scaffold.yml and tenant-deploy.yml directly from the
#      Payload admin UI via /api/tenants/:id/scaffold and /deploy.
#
# Token permissions needed:
#   actions:write          (for both workflows)
#   contents:write         (so tenant-scaffold can push a branch)
#   pull_requests:write    (so tenant-scaffold can open a PR)
#
# Easiest: a fine-grained Personal Access Token scoped to this repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Branch the workflows run on. Defaults to "main" if omitted.
GITHUB_BRANCH=main

# Optional: same PAT as GitHub secret EXTERNAL_REPO_GITHUB_TOKEN (client repo checkout fallback).
# When a tenant has no linked GitHub credential, CI and /api/ci/github-token use this, then GITHUB_TOKEN.
# EXTERNAL_REPO_GITHUB_TOKEN=

# Encrypt GitHub credentials stored in Payload (github-credentials collection).
# Generate: openssl rand -base64 32
# Falls back to DEPLOY_REPORT_TOKEN / PAYLOAD_SECRET if unset (not recommended for production).
# CREDENTIALS_ENCRYPTION_KEY=

# Shared secret for GitHub Actions → report-deploy, import-blog-content, /api/ci/github-token, etc.
# Must match GitHub repo secret DEPLOY_REPORT_TOKEN exactly.
# Also authorizes REST reads on tenants / blog-posts / media when sent as header x-deploy-report-token.
# Generate: openssl rand -hex 32
# DEPLOY_REPORT_TOKEN=

# Per-user API keys (Payload admin → Users → Enable API Key) are used as GitHub secret PAYLOAD_API_KEY.
# Required for tenant-cli sync and external-repo blog pulls after CMS REST auth is enabled.

# Optional: account workers.dev subdomain (e.g. "my-account") used to build
# https://<slug>.<subdomain>.workers.dev when wrangler output cannot be parsed.
# CLOUDFLARE_WORKERS_DEV_SUBDOMAIN=
