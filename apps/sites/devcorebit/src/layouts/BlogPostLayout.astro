---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { TENANT } from '../consts';

interface Props {
	entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, categories, author } = entry.data;

const dateFormatter = new Intl.DateTimeFormat('nl-NL', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
const formattedPubDate = dateFormatter.format(pubDate);
const firstCategory = categories?.[0];

// Astro's image() processed hero (if present) exposes .src as a runtime path.
// For JSON-LD and og:image we want an absolute URL.
const heroImageAbsolute = heroImage
	? new URL(heroImage.src, Astro.site).toString()
	: undefined;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: {
		'@type': 'Organization',
		name: author ?? TENANT.name,
	},
	publisher: {
		'@type': 'Organization',
		name: TENANT.name,
		logo: {
			'@type': 'ImageObject',
			url: TENANT.logo ?? new URL('/og-default.png', Astro.site).toString(),
		},
	},
	...(heroImageAbsolute ? { image: heroImageAbsolute } : {}),
	mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
};
---

<BaseLayout
	title={title}
	description={description}
	ogImage={heroImage?.src}
	ogType="article"
	preloadImage={heroImage?.src}
	jsonLd={jsonLd}
>
	<article>
		<header class="mx-auto max-w-3xl px-4 pb-8 pt-12 md:pt-16">
			<h1 class="text-3xl font-bold tracking-tight text-navy-900 md:text-5xl">
				{title}
			</h1>
			<div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
				<time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
				{firstCategory && (
					<span
						class="inline-block rounded-full bg-coral-600/10 px-3 py-1 text-xs font-semibold text-coral-600"
					>
						{firstCategory}
					</span>
				)}
			</div>
		</header>

		{heroImage && (
			<div class="mx-auto mb-8 max-w-4xl px-4">
				<Image
					src={heroImage}
					alt={title}
					widths={[400, 800, 1200]}
					sizes="(min-width: 1024px) 1024px, 100vw"
					loading="eager"
					fetchpriority="high"
					decoding="async"
					class="mx-auto max-h-[700px] w-full rounded-lg object-cover"
				/>
			</div>
		)}

		<div class="mx-auto max-w-3xl px-4 pb-8">
			<div class="prose prose-lg mx-auto">
				<slot />
			</div>
		</div>

		<footer class="mx-auto max-w-3xl px-4 pb-16 text-sm text-gray-500">
			Gepubliceerd: <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
			{updatedDate && (
				<> · Laatst bijgewerkt: <time datetime={updatedDate.toISOString()}>
					{dateFormatter.format(updatedDate)}
				</time></>
			)}
		</footer>
	</article>
</BaseLayout>
