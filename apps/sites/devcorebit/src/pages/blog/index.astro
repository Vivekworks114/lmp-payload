---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('nl-NL', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
---

<BaseLayout title="Blog — keukenfaqs" description="Alle blog-artikelen van keukenfaqs.">
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<header class="mb-10">
			<h1 class="text-3xl font-bold tracking-tight text-navy-900 md:text-5xl">Blog</h1>
			<p class="mt-3 text-gray-500">Alle blog-artikelen van keukenfaqs.</p>
		</header>

		<ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
			{posts.map((post, i) => (
				<li>
					<a
						href={`/${post.id}/`}
						class="group block h-full overflow-hidden rounded-lg border border-gray-200 bg-white no-underline transition-shadow hover:shadow-md"
					>
						<div class="aspect-[16/10] w-full bg-gradient-to-br from-navy-700 to-navy-900">
							{post.data.heroImage && (
								<Image
									src={post.data.heroImage}
									alt=""
									widths={[400, 600, 800]}
									sizes="(min-width: 1024px) 400px, (min-width: 768px) 50vw, 100vw"
									loading={i < 3 ? 'eager' : 'lazy'}
									decoding="async"
									class="h-full w-full object-cover"
								/>
							)}
						</div>
						<div class="p-5">
							{post.data.categories?.[0] && (
								<span class="inline-block rounded-full border border-coral-600 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-coral-600">
									{post.data.categories[0]}
								</span>
							)}
							<h2
								class="mt-3 line-clamp-2 text-lg font-bold text-navy-700 transition-colors group-hover:text-coral-600"
							>
								{post.data.title}
							</h2>
							<time
								class="mt-1 block text-xs text-gray-500"
								datetime={post.data.pubDate.toISOString()}
							>
								{dateFormatter.format(post.data.pubDate)}
							</time>
							<p class="mt-3 line-clamp-3 text-sm text-gray-900">
								{post.data.description}
							</p>
						</div>
					</a>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>
