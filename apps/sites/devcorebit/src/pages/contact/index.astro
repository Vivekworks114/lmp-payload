---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Web3Forms access key. Public by design — Web3Forms is built around a
// client-exposed access key plus server-side spam filtering (honeypot,
// hCaptcha, rate limits). No env var indirection needed.
const ACCESS_KEY = '7f1dcfbd-3354-4903-be1f-62abadc311ee';
const RECIPIENT_EMAIL = 'info@zbseo.uk';
const SUBJECT = 'Nieuw bericht via keukenfaqs.nl';
const FROM_NAME = 'keukenfaqs contactformulier';
---

<BaseLayout
	title="Contact — keukenfaqs"
	description="Neem contact op met de redactie van keukenfaqs. We reageren zo snel mogelijk op je vraag of tip."
>
	<section class="mx-auto max-w-2xl px-4 py-12 md:py-16">
		<header class="mb-8">
			<h1 class="text-3xl font-bold tracking-tight text-navy-700 md:text-5xl">
				Contact
			</h1>
			<p class="mt-4 text-base text-gray-900 max-w-prose">
				Heb je een vraag of tip voor ons? Vul onderstaand formulier in en we
				reageren zo snel mogelijk.
			</p>
		</header>

		<form
			id="contact-form"
			class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm md:p-8"
		>
			<input type="hidden" name="access_key" value={ACCESS_KEY} />
			<input type="hidden" name="subject" value={SUBJECT} />
			<input type="hidden" name="from_name" value={FROM_NAME} />

			<!-- Honeypot: bots fill all fields, real users don't see this one. -->
			<input
				type="text"
				name="botcheck"
				class="sr-only"
				tabindex="-1"
				aria-hidden="true"
				autocomplete="off"
			/>

			<div class="space-y-5">
				<div>
					<label for="naam" class="mb-1.5 block text-sm font-semibold text-navy-900">
						Naam
					</label>
					<input
						id="naam"
						name="naam"
						type="text"
						required
						autocomplete="name"
						class="w-full rounded border border-gray-200 bg-white px-3 py-2 text-base text-gray-900 transition-colors focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-700"
					/>
				</div>

				<div>
					<label for="email" class="mb-1.5 block text-sm font-semibold text-navy-900">
						E-mailadres
					</label>
					<input
						id="email"
						name="email"
						type="email"
						required
						autocomplete="email"
						class="w-full rounded border border-gray-200 bg-white px-3 py-2 text-base text-gray-900 transition-colors focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-700"
					/>
				</div>

				<div>
					<label for="onderwerp" class="mb-1.5 block text-sm font-semibold text-navy-900">
						Onderwerp
					</label>
					<input
						id="onderwerp"
						name="onderwerp"
						type="text"
						required
						class="w-full rounded border border-gray-200 bg-white px-3 py-2 text-base text-gray-900 transition-colors focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-700"
					/>
				</div>

				<div>
					<label for="bericht" class="mb-1.5 block text-sm font-semibold text-navy-900">
						Bericht
					</label>
					<textarea
						id="bericht"
						name="bericht"
						rows="6"
						required
						class="w-full rounded border border-gray-200 bg-white px-3 py-2 text-base text-gray-900 transition-colors focus:border-navy-700 focus:outline-none focus:ring-2 focus:ring-navy-700"
					></textarea>
				</div>

				<div>
					<!-- Web3Forms-managed hCaptcha widget. The bundled client script
					     (loaded below) renders the widget into this div on page load
					     and injects a hidden <textarea name="h-captcha-response">
					     once the user solves it. -->
					<div class="h-captcha" data-captcha="true"></div>
					<p
						id="contact-captcha-error"
						class="mt-2 hidden text-sm text-coral-700"
						role="alert"
					>
						Vul de captcha in voordat je verzendt.
					</p>
				</div>

				<button
					type="submit"
					class="btn w-full sm:w-auto"
					id="contact-submit"
				>
					Verstuur bericht
				</button>
			</div>
		</form>

		<div
			id="contact-success"
			class="mt-6 hidden rounded-lg border border-navy-700 bg-white p-6"
			role="status"
			aria-live="polite"
		>
			<div class="flex items-start gap-3">
				<svg
					class="h-6 w-6 flex-shrink-0 fill-none stroke-navy-700"
					viewBox="0 0 24 24"
					stroke-width="2.5"
					aria-hidden="true"
				>
					<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
				</svg>
				<p class="text-base text-navy-900">
					Bedankt voor je bericht! We nemen zo snel mogelijk contact op.
				</p>
			</div>
		</div>

		<div
			id="contact-error"
			class="mt-6 hidden rounded-lg border border-coral-700 bg-white p-4 text-sm text-coral-700"
			role="alert"
		>
			Er ging iets mis. Probeer het later opnieuw of mail rechtstreeks naar
			<a href={`mailto:${RECIPIENT_EMAIL}`} class="font-semibold underline">
				{RECIPIENT_EMAIL}
			</a>.
		</div>

		<p class="mt-6 text-sm text-gray-500">
			Je gegevens worden alleen gebruikt om je bericht te beantwoorden en niet
			opgeslagen.
		</p>
	</section>

	<!-- Web3Forms client script: renders the hCaptcha widget via the
	     `.h-captcha[data-captcha="true"]` selector. Loaded async so it
	     does not block first paint. -->
	<script is:inline async defer src="https://web3forms.com/client/script.js"></script>
</BaseLayout>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
	const successEl = document.getElementById('contact-success');
	const errorEl = document.getElementById('contact-error');
	const captchaErrorEl = document.getElementById('contact-captcha-error');

	if (form && submitBtn) {
		const originalLabel = submitBtn.textContent ?? 'Verstuur bericht';

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			errorEl?.classList.add('hidden');
			captchaErrorEl?.classList.add('hidden');

			// hCaptcha guard: the widget injects this hidden field with a token
			// once the user solves it. Empty value means unsolved → block submit.
			const captchaToken = (
				form.querySelector('textarea[name="h-captcha-response"]') as HTMLTextAreaElement | null
			)?.value;
			if (!captchaToken) {
				captchaErrorEl?.classList.remove('hidden');
				return;
			}

			submitBtn.textContent = 'Versturen...';
			submitBtn.disabled = true;

			const formData = new FormData(form);
			const payload = Object.fromEntries(formData.entries());

			try {
				const res = await fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
						Accept: 'application/json',
					},
					body: JSON.stringify(payload),
				});
				const json = await res.json().catch(() => ({}));
				if (!res.ok || json.success === false) {
					throw new Error(json.message || `HTTP ${res.status}`);
				}
				form.classList.add('hidden');
				successEl?.classList.remove('hidden');
				successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
			} catch (err) {
				console.error('[contact-form]', err);
				submitBtn.textContent = originalLabel;
				submitBtn.disabled = false;
				errorEl?.classList.remove('hidden');
			}
		});
	}
</script>
