---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const allBusinesses = (
		await getCollection('moneyPages', (e) => e.data.page_type === 'business')
	).sort((a, b) => {
		if (a.data.page_type !== 'business' || b.data.page_type !== 'business') return 0;
		const an = a.data.business.name ?? a.data.title;
		const bn = b.data.business.name ?? b.data.title;
		return an.localeCompare(bn);
	});

	// Build city index once; pass it as a static prop to every paginated page.
	const cityCounts = new Map<string, number>();
	for (const b of allBusinesses) {
		if (b.data.page_type !== 'business') continue;
		const c = b.data.business.city;
		if (!c) continue;
		cityCounts.set(c, (cityCounts.get(c) ?? 0) + 1);
	}
	const topCities = [...cityCounts.entries()]
		.filter(([, n]) => n >= 5)
		.sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));

	return paginate(allBusinesses, {
		pageSize: 60,
		props: { topCities, totalCities: cityCounts.size },
	});
}

const { page, topCities, totalCities } = Astro.props;
const pageLabel = page.currentPage > 1 ? ` — pagina ${page.currentPage}` : '';
const title = `Keukenzaken${pageLabel} — keukenfaqs`;

function pageList(current: number, last: number): Array<number | '…'> {
	const out = new Set<number>();
	out.add(1);
	out.add(last);
	for (let i = Math.max(1, current - 2); i <= Math.min(last, current + 2); i++) out.add(i);
	const sorted = [...out].sort((a, b) => a - b);
	const result: Array<number | '…'> = [];
	for (let i = 0; i < sorted.length; i++) {
		if (i > 0 && sorted[i] - sorted[i - 1] > 1) result.push('…');
		result.push(sorted[i]);
	}
	return result;
}
const pages = pageList(page.currentPage, page.lastPage);
---

<BaseLayout
	title={title}
	description="Keukenzaken in Nederland — een directory van keukenspecialisten en retailers."
>
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<header class="mb-8">
			<h1 class="text-3xl font-bold tracking-tight text-navy-900 md:text-5xl">Keukenzaken</h1>
			<p class="mt-3 text-gray-500">
				{page.total} keukenzaken in {totalCities} Nederlandse steden · pagina {page.currentPage} van {page.lastPage}
			</p>
		</header>

		{page.currentPage === 1 && topCities.length > 0 && (
			<section class="mb-10 rounded-lg border border-gray-200 bg-gray-50 p-5">
				<h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500">
					Grootste steden
				</h2>
				<ul class="mt-3 flex flex-wrap gap-2">
					{topCities.map(([city, n]) => (
						<li>
							<span class="inline-flex items-center gap-1.5 rounded-full bg-white px-3 py-1 text-sm text-navy-700 shadow-sm">
								{city}
								<span class="text-xs text-gray-500">{n}</span>
							</span>
						</li>
					))}
				</ul>
			</section>
		)}

		<ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{page.data.map((entry) => {
				if (entry.data.page_type !== 'business') return null;
				const b = entry.data.business;
				const displayName = b.name ?? entry.data.title;
				return (
					<li>
						<a
							href={`/${entry.data.slug}/`}
							class="block h-full rounded-lg border border-gray-200 bg-white p-4 no-underline transition-colors hover:border-navy-700"
						>
							{b.city && (
								<span class="inline-block rounded-full bg-coral-600/10 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-coral-600">
									{b.city}
								</span>
							)}
							<h2 class="mt-2 line-clamp-2 text-base font-bold text-navy-700">
								{displayName}
							</h2>
							{b.address && (
								<p class="mt-1 line-clamp-1 text-sm text-gray-500">
									{b.address}
								</p>
							)}
						</a>
					</li>
				);
			})}
		</ul>

		<nav aria-label="Paginering" class="mt-10 flex flex-wrap items-center justify-center gap-2 text-sm">
			{page.url.prev ? (
				<a
					href={page.url.prev}
					class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
				>
					← Vorige
				</a>
			) : (
				<span class="rounded border border-gray-200 bg-gray-50 px-3 py-2 font-semibold text-gray-400">
					← Vorige
				</span>
			)}
			{pages.map((p) =>
				p === '…' ? (
					<span class="px-2 text-gray-500">…</span>
				) : p === page.currentPage ? (
					<span class="rounded bg-navy-700 px-3 py-2 font-semibold text-white">
						{p}
					</span>
				) : (
					<a
						href={p === 1 ? '/keukenzaken/' : `/keukenzaken/${p}/`}
						class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
					>
						{p}
					</a>
				)
			)}
			{page.url.next ? (
				<a
					href={page.url.next}
					class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
				>
					Volgende →
				</a>
			) : (
				<span class="rounded border border-gray-200 bg-gray-50 px-3 py-2 font-semibold text-gray-400">
					Volgende →
				</span>
			)}
		</nav>
	</section>
</BaseLayout>
