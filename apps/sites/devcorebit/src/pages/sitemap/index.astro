---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const top10s = (
	await getCollection('moneyPages', (e) => e.data.page_type === 'top10')
).sort((a, b) => {
	if (a.data.page_type !== 'top10' || b.data.page_type !== 'top10') return 0;
	return (a.data.top10.category_singular ?? '').localeCompare(
		b.data.top10.category_singular ?? ''
	);
});

const businesses = await getCollection(
	'moneyPages',
	(e) => e.data.page_type === 'business'
);
const totalProducts = (
	await getCollection('moneyPages', (e) => e.data.page_type === 'product')
).length;

const cityCount = new Map<string, number>();
for (const b of businesses) {
	if (b.data.page_type !== 'business') continue;
	const c = b.data.business.city;
	if (!c) continue;
	cityCount.set(c, (cityCount.get(c) ?? 0) + 1);
}
const citiesAlphabetical = [...cityCount.entries()].sort((a, b) =>
	a[0].localeCompare(b[0], 'nl')
);

const dateFormatter = new Intl.DateTimeFormat('nl-NL', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const mainPages = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog/' },
	{ label: 'Reviews', href: '/reviews/' },
	{ label: 'Producten', href: '/producten/' },
	{ label: 'Keukenzaken', href: '/keukenzaken/' },
	{ label: 'Contact', href: '/contact/' },
	{ label: 'Over ons', href: '/over-ons/' },
];
---

<BaseLayout
	title="Sitemap — keukenfaqs"
	description="Overzicht van alle pagina's op keukenfaqs."
>
	<section class="mx-auto max-w-4xl px-4 py-12 md:py-16">
		<header class="mb-10">
			<h1 class="text-3xl font-bold tracking-tight text-navy-700 md:text-5xl">
				Sitemap
			</h1>
			<p class="mt-3 text-gray-500">
				Een volledig overzicht van alle secties op keukenfaqs.nl.
			</p>
		</header>

		<!-- HOOFDPAGINA'S -->
		<section>
			<h2 class="text-2xl font-bold text-navy-700">Hoofdpagina's</h2>
			<ul class="mt-4 grid grid-cols-2 gap-2 text-base sm:grid-cols-3 md:grid-cols-4">
				{mainPages.map((p) => (
					<li>
						<a href={p.href} class="no-underline hover:text-coral-600">
							{p.label}
						</a>
					</li>
				))}
			</ul>
		</section>

		<!-- BLOG-ARTIKELEN -->
		<section class="mt-10 border-t border-gray-200 pt-10">
			<h2 class="text-2xl font-bold text-navy-700">
				Blog-artikelen
				<span class="ml-2 text-base font-normal text-gray-500">
					({blogPosts.length})
				</span>
			</h2>
			<ul class="mt-4 space-y-1.5 text-base">
				{blogPosts.map((post) => (
					<li class="flex flex-wrap items-baseline gap-x-3">
						<a
							href={`/${post.id}/`}
							class="no-underline hover:text-coral-600"
						>
							{post.data.title}
						</a>
						<time
							datetime={post.data.pubDate.toISOString()}
							class="text-sm text-gray-500"
						>
							{dateFormatter.format(post.data.pubDate)}
						</time>
					</li>
				))}
			</ul>
		</section>

		<!-- REVIEWS -->
		<section class="mt-10 border-t border-gray-200 pt-10">
			<h2 class="text-2xl font-bold text-navy-700">
				Reviews
				<span class="ml-2 text-base font-normal text-gray-500">
					({top10s.length})
				</span>
			</h2>
			<ul class="mt-4 grid grid-cols-1 gap-1.5 text-base sm:grid-cols-2 md:grid-cols-3">
				{top10s.map((r) => {
					if (r.data.page_type !== 'top10') return null;
					const label = r.data.top10.category_singular ?? r.data.slug;
					return (
						<li>
							<a
								href={`/${r.data.slug}/`}
								class="capitalize no-underline hover:text-coral-600"
							>
								{label}
							</a>
						</li>
					);
				})}
			</ul>
		</section>

		<!-- PRODUCTEN OVERVIEW -->
		<section class="mt-10 border-t border-gray-200 pt-10">
			<h2 class="text-2xl font-bold text-navy-700">Producten (overzicht)</h2>
			<p class="mt-3 text-gray-500">
				Gepagineerd op aparte categoriepagina's.
			</p>
			<p class="mt-3">
				<a
					href="/producten/"
					class="font-semibold text-navy-700 no-underline hover:text-coral-600"
				>
					Bekijk alle {totalProducts} producten →
				</a>
			</p>
		</section>

		<!-- KEUKENZAKEN PER STAD -->
		<section class="mt-10 border-t border-gray-200 pt-10">
			<h2 class="text-2xl font-bold text-navy-700">
				Keukenzaken per stad
				<span class="ml-2 text-base font-normal text-gray-500">
					({citiesAlphabetical.length} steden, {businesses.length} keukenzaken)
				</span>
			</h2>
			<ul class="mt-4 grid grid-cols-2 gap-1.5 text-base sm:grid-cols-3 md:grid-cols-4">
				{citiesAlphabetical.map(([city, n]) => (
					<li>
						<a href="/keukenzaken/" class="no-underline hover:text-coral-600">
							{city}
							<span class="text-sm text-gray-500"> ({n})</span>
						</a>
					</li>
				))}
			</ul>
		</section>
	</section>
</BaseLayout>
