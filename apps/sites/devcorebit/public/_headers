# Cloudflare Workers / Pages static-asset headers.
# Copied to dist/_headers at build time via Astro's public/ pipeline.
# Syntax: path pattern, followed by indented "Header: value" lines.

# Astro's hashed build output (CSS bundles, optimized images, etc.)
# is content-addressed — safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — filenames never change; 1 year immutable cache.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Default Open Graph image — 30 days.
/og-default.png
  Cache-Control: public, max-age=2592000

# Favicons — 30 days.
/favicon.ico
  Cache-Control: public, max-age=2592000
/favicon.svg
  Cache-Control: public, max-age=2592000

# HTML pages — short cache so content updates propagate fast.
# must-revalidate forces a revalidation even for fresh cache.
/*
  Cache-Control: public, max-age=300, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
