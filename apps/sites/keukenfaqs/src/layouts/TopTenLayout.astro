---
import BaseLayout from './BaseLayout.astro';

interface Props {
	data: {
		title: string;
		meta_description: string | null;
		last_updated: string | null;
		top10: {
			category_singular: string | null;
			category_plural: string | null;
			intro: string | null;
			products: Array<{
				rank: number;
				name: string;
				image_url: string | null;
				description: string | null;
				affiliate_url: string | null;
				affiliate_network: string | null;
			}>;
			faq: Array<{ question: string; answer_html: string }>;
			conclusion: string | null;
		};
	};
}

const { data } = Astro.props;
const { title, meta_description, last_updated, top10 } = data;
const category = top10.category_singular ?? top10.category_plural;
const sortedProducts = [...top10.products].sort((a, b) => a.rank - b.rank);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const itemListLd = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: title,
	numberOfItems: sortedProducts.length,
	itemListElement: sortedProducts.map((p) => ({
		'@type': 'ListItem',
		position: p.rank,
		name: p.name,
		...(p.affiliate_url ? { url: p.affiliate_url } : {}),
		...(p.image_url ? { image: p.image_url } : {}),
	})),
};
const faqLd = top10.faq.length > 0
	? {
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: top10.faq.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: { '@type': 'Answer', text: item.answer_html },
		})),
	}
	: null;
const jsonLd = faqLd ? [itemListLd, faqLd] : itemListLd;

const heroImage = sortedProducts[0]?.image_url ?? undefined;
---

<BaseLayout
	title={title}
	description={meta_description ?? title}
	ogImage={heroImage}
	ogType="article"
	preloadImage={heroImage}
	jsonLd={jsonLd}
>
	<article>
		<header class="mx-auto max-w-4xl px-4 pb-6 pt-12 md:pt-16">
			<h1 class="text-3xl font-bold tracking-tight text-navy-700 md:text-5xl">
				{title}
			</h1>
			{meta_description && (
				<p class="mt-4 max-w-3xl text-base text-gray-500 md:text-lg">
					{meta_description}
				</p>
			)}
			<div class="mt-5 flex flex-wrap items-center gap-3 text-sm">
				{category && (
					<span
						class="inline-block rounded-full bg-coral-600/10 px-3 py-1 text-xs font-semibold text-coral-600"
					>
						{category}
					</span>
				)}
				{last_updated && (
					<span class="text-gray-500">Laatst bijgewerkt: {last_updated}</span>
				)}
			</div>
		</header>

		{top10.intro && (
			<section class="mx-auto max-w-3xl px-4 pb-8">
				<div class="prose prose-lg mx-auto">
					<p>{top10.intro}</p>
				</div>
			</section>
		)}

		<section class="mx-auto max-w-4xl px-4 pb-12">
			<ol class="space-y-6">
				{sortedProducts.map((p) => (
					<li
						class="flex flex-col gap-4 rounded-lg border border-gray-200 bg-white p-5 sm:flex-row sm:gap-6 sm:p-6"
					>
						<div class="flex sm:block">
							<span
								class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-coral-600 text-lg font-bold text-white sm:h-14 sm:w-14 sm:text-xl"
								aria-hidden="true"
							>
								{p.rank}
							</span>
						</div>
						{p.image_url && (
							<img
								src={p.image_url}
								alt={p.name}
								width="400"
								height="400"
								loading={p.rank <= 2 ? 'eager' : 'lazy'}
								fetchpriority={p.rank === 1 ? 'high' : undefined}
								decoding="async"
								class="mx-auto h-40 w-40 flex-shrink-0 rounded object-contain sm:mx-0 sm:h-48 sm:w-48"
							/>
						)}
						<div class="flex min-w-0 flex-1 flex-col">
							<h3 class="text-xl font-bold text-navy-700 md:text-2xl">
								{p.name}
							</h3>
							{p.description && (
								<div class="prose prose-sm mt-2 max-w-none text-gray-900">
									<p>{p.description}</p>
								</div>
							)}
							{p.affiliate_url && (
								<p class="mt-4">
									<a
										class="btn"
										href={p.affiliate_url}
										target="_blank"
										rel="noopener sponsored"
									>
										Goedkoopste deal hier
									</a>
								</p>
							)}
						</div>
					</li>
				))}
			</ol>
		</section>

		{top10.faq.length > 0 && (
			<section class="mx-auto max-w-3xl px-4 pb-12">
				<h2 class="text-2xl font-bold text-navy-900 md:text-3xl">
					Veelgestelde vragen
				</h2>
				<div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
					{top10.faq.map((item) => (
						<details class="group px-5 py-4">
							<summary
								class="cursor-pointer list-none text-base font-semibold text-navy-900 hover:text-coral-600 [&::-webkit-details-marker]:hidden"
							>
								<span class="mr-2 inline-block transition-transform group-open:rotate-90" aria-hidden="true">›</span>
								{item.question}
							</summary>
							<div class="prose prose-sm mt-3 max-w-none text-gray-900" set:html={item.answer_html} />
						</details>
					))}
				</div>
			</section>
		)}

		{top10.conclusion && (
			<section class="mx-auto max-w-3xl px-4 pb-16">
				<div class="prose prose-lg mx-auto">
					<p>{top10.conclusion}</p>
				</div>
			</section>
		)}

		<footer class="mx-auto max-w-3xl px-4 pb-16 text-xs text-gray-500">
			Dit artikel bevat affiliate-links. Als je iets koopt via een link, ontvangen
			wij een kleine commissie.
		</footer>
	</article>
</BaseLayout>
