---
import { getCollection } from 'astro:content';
import { TENANT } from '../consts';

const year = new Date().getFullYear();

const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<footer class="mt-16 bg-gray-50 text-gray-500">
	<div class="mx-auto max-w-6xl px-4 py-12">
		<div class="grid grid-cols-1 gap-8 md:grid-cols-2">
			<div>
				<a href="/" class="text-xl font-bold text-navy-700 no-underline">
					{TENANT.name}
				</a>
				<p class="mt-3 max-w-sm text-sm leading-relaxed">{TENANT.siteDescription}</p>
				<nav aria-label="Site navigatie" class="mt-5">
					<ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
						<li>
							<a href="/blog/" class="no-underline hover:text-coral-600">Blog</a>
						</li>
						<li>
							<a href="/over-ons/" class="no-underline hover:text-coral-600">Over ons</a>
						</li>
						<li>
							<a href="/contact/" class="no-underline hover:text-coral-600">Contact</a>
						</li>
					</ul>
				</nav>
			</div>

			<nav aria-label="Laatste artikelen">
				<h2 class="mb-3 text-sm font-semibold uppercase tracking-wide text-navy-900">
					Laatste artikelen
				</h2>
				<ul class="space-y-2 text-sm">
					{latestPosts.map((post) => (
						<li>
							<a
								href={`/${post.id}/`}
								class="line-clamp-1 no-underline hover:text-coral-600"
							>
								{post.data.title}
							</a>
						</li>
					))}
				</ul>
				<p class="mt-4">
					<a href="/blog/" class="text-sm font-semibold text-navy-700 no-underline hover:text-coral-600">
						Alle artikelen →
					</a>
				</p>
			</nav>
		</div>

		<div class="mt-10 flex flex-col gap-3 border-t border-gray-200 pt-6 text-sm md:flex-row md:items-center md:justify-between">
			<p>© {year} {TENANT.name}. Alle rechten voorbehouden.</p>
			<nav aria-label="Footer secundair">
				<a href="/sitemap/" class="text-navy-700 no-underline hover:text-coral-600">
					Sitemap
				</a>
			</nav>
		</div>
	</div>
</footer>
