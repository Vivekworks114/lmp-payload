---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('nl-NL', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const mainPages = [
	{ label: 'Home', href: '/' },
	{ label: 'Blog', href: '/blog/' },
	{ label: 'Contact', href: '/contact/' },
	{ label: 'Over ons', href: '/over-ons/' },
];
---

<BaseLayout title="Sitemap" description="Overzicht van alle pagina's op deze site.">
	<div class="mx-auto max-w-3xl px-4 py-12">
		<h1 class="text-3xl font-bold text-navy-900">Sitemap</h1>

		<section class="mt-10">
			<h2 class="text-xl font-semibold text-navy-800">Pagina's</h2>
			<ul class="mt-4 space-y-2">
				{mainPages.map((p) => (
					<li>
						<a href={p.href} class="text-navy-700 underline-offset-2 hover:underline">
							{p.label}
						</a>
					</li>
				))}
			</ul>
		</section>

		<section class="mt-10">
			<h2 class="text-xl font-semibold text-navy-800">Blog</h2>
			<ul class="mt-4 space-y-3">
				{blogPosts.map((post) => (
					<li>
						<a href={`/${post.id}/`} class="font-medium text-navy-700 underline-offset-2 hover:underline">
							{post.data.title}
						</a>
						<time class="ml-2 text-sm text-gray-500" datetime={post.data.pubDate.toISOString()}>
							{dateFormatter.format(post.data.pubDate)}
						</time>
					</li>
				))}
			</ul>
		</section>
	</div>
</BaseLayout>
