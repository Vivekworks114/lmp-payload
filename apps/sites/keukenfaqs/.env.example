# Astro tenant app environment.
# Copy to .env and fill in the values below. The Astro dev server and the
# `sync:content` script auto-load this file via `tsx --env-file=.env` / Astro.

# --- Sync (required by scripts/sync-content.ts) ---

# URL of the running Payload CMS instance.
PAYLOAD_URL=http://localhost:3000

# Per-user API key. Generate in Payload admin:
#   Admin -> Users -> <your user> -> "Enable API Key" checkbox -> Save.
# Copy the value from the "API Key" field after save.
PAYLOAD_API_KEY=

# Tenant slug to pull from Payload (filters every query with where[tenant][slug]).
# Must match the slug column in Payload's `tenants` table.
TENANT=keukenfaqs

# --- Build / runtime (optional) ---

# When deploying as a Cloudflare Worker, these come from Wrangler `vars` /
# `secret put` instead, not this file.
# See wrangler.jsonc.
