---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const roundups = (
	await getCollection('moneyPages', (e) => e.data.page_type === 'top10')
).sort((a, b) => {
	if (a.data.page_type !== 'top10' || b.data.page_type !== 'top10') return 0;
	return (a.data.top10.category_singular ?? '').localeCompare(
		b.data.top10.category_singular ?? ''
	);
});
---

<BaseLayout
	title="Reviews — keukenfaqs"
	description="Top-10 vergelijkingen van keukenproducten. Onafhankelijk onderzocht en geschreven."
>
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<header class="mb-10">
			<h1 class="text-3xl font-bold tracking-tight text-navy-900 md:text-5xl">Reviews</h1>
			<p class="mt-3 text-gray-500">
				{roundups.length} top-10 vergelijkingen van keukenproducten.
			</p>
		</header>

		<ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
			{roundups.map((r, i) => {
				if (r.data.page_type !== 'top10') return null;
				const heroImage = r.data.top10.products[0]?.image_url ?? null;
				const plural = r.data.top10.category_plural ?? r.data.top10.category_singular;
				const eager = i < 3;
				return (
					<li>
						<a
							href={`/${r.data.slug}/`}
							class="group block h-full overflow-hidden rounded-lg border border-gray-200 bg-white no-underline transition-shadow hover:shadow-md"
						>
							<div class="aspect-[16/10] w-full bg-gradient-to-br from-navy-700 to-navy-900">
								{heroImage && (
									<img
										src={heroImage}
										alt=""
										width="400"
										height="400"
										loading={eager ? 'eager' : 'lazy'}
										decoding="async"
										class="h-full w-full object-contain"
									/>
								)}
							</div>
							<div class="p-5">
								<h2 class="line-clamp-2 text-lg font-bold capitalize text-navy-700 transition-colors group-hover:text-coral-600">
									{plural}
								</h2>
								<p class="mt-2 text-sm text-gray-500">
									Top 10 beste {plural}
								</p>
							</div>
						</a>
					</li>
				);
			})}
		</ul>
	</section>
</BaseLayout>
