---
import type { GetStaticPathsOptions } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const products = (
		await getCollection('moneyPages', (e) => e.data.page_type === 'product')
	).sort((a, b) => {
		if (a.data.page_type !== 'product' || b.data.page_type !== 'product') return 0;
		const an = a.data.product.name ?? a.data.title;
		const bn = b.data.product.name ?? b.data.title;
		return an.localeCompare(bn);
	});
	return paginate(products, { pageSize: 60 });
}

const { page } = Astro.props;
const pageLabel = page.currentPage > 1 ? ` — pagina ${page.currentPage}` : '';
const title = `Producten${pageLabel} — keukenfaqs`;

// Build a compact page-number list (current ± 2, plus first and last).
function pageList(current: number, last: number): Array<number | '…'> {
	const out = new Set<number>();
	out.add(1);
	out.add(last);
	for (let i = Math.max(1, current - 2); i <= Math.min(last, current + 2); i++) out.add(i);
	const sorted = [...out].sort((a, b) => a - b);
	const result: Array<number | '…'> = [];
	for (let i = 0; i < sorted.length; i++) {
		if (i > 0 && sorted[i] - sorted[i - 1] > 1) result.push('…');
		result.push(sorted[i]);
	}
	return result;
}
const pages = pageList(page.currentPage, page.lastPage);
---

<BaseLayout
	title={title}
	description="Alle keukenproducten op keukenfaqs — airfryers, keukenmachines, pannen en meer."
>
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<header class="mb-8">
			<h1 class="text-3xl font-bold tracking-tight text-navy-900 md:text-5xl">Producten</h1>
			<p class="mt-3 text-gray-500">
				{page.total} producten · pagina {page.currentPage} van {page.lastPage}
			</p>
		</header>

		<ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{page.data.map((entry, i) => {
				if (entry.data.page_type !== 'product') return null;
				const p = entry.data.product;
				const displayName = p.name ?? entry.data.title;
				const rating = Math.round(p.rating ?? 0);
				const eager = i < 3;
				return (
					<li>
						<a
							href={`/${entry.data.slug}/`}
							class="group block h-full overflow-hidden rounded-lg border border-gray-200 bg-white no-underline transition-shadow hover:shadow-md"
						>
							<div class="flex aspect-square w-full items-center justify-center bg-white p-4">
								{p.image_url ? (
									<img
										src={p.image_url}
										alt={displayName}
										width="400"
										height="400"
										loading={eager ? 'eager' : 'lazy'}
										decoding="async"
										class="h-full w-full object-contain"
									/>
								) : (
									<div class="flex h-full w-full items-center justify-center rounded bg-gradient-to-br from-navy-700 to-navy-900 text-white">
										Geen afbeelding
									</div>
								)}
							</div>
							<div class="border-t border-gray-200 p-4">
								{p.category && (
									<p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
										{p.category}
									</p>
								)}
								<h2 class="mt-1 line-clamp-2 text-base font-bold text-navy-700 transition-colors group-hover:text-coral-600">
									{displayName}
								</h2>
								{rating > 0 && (
									<div class="mt-2 flex items-center gap-1" aria-label={`Waardering ${rating} van 5`}>
										{Array.from({ length: 5 }).map((_, i) => (
											<svg
												class={`h-4 w-4 ${i < rating ? 'fill-coral-600' : 'fill-none stroke-coral-300'}`}
												viewBox="0 0 20 20"
												stroke-width="1.5"
												aria-hidden="true"
											>
												<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.916c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.364 1.118l1.519 4.674c.3.922-.755 1.688-1.54 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.784.57-1.838-.196-1.539-1.118l1.519-4.674a1 1 0 00-.364-1.118L2.098 10.1c-.783-.57-.38-1.81.588-1.81h4.915a1 1 0 00.951-.69l1.519-4.674z" />
											</svg>
										))}
									</div>
								)}
							</div>
						</a>
					</li>
				);
			})}
		</ul>

		<nav aria-label="Paginering" class="mt-10 flex flex-wrap items-center justify-center gap-2 text-sm">
			{page.url.prev ? (
				<a
					href={page.url.prev}
					class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
				>
					← Vorige
				</a>
			) : (
				<span class="rounded border border-gray-200 bg-gray-50 px-3 py-2 font-semibold text-gray-400">
					← Vorige
				</span>
			)}
			{pages.map((p) =>
				p === '…' ? (
					<span class="px-2 text-gray-500">…</span>
				) : p === page.currentPage ? (
					<span class="rounded bg-navy-700 px-3 py-2 font-semibold text-white">
						{p}
					</span>
				) : (
					<a
						href={p === 1 ? '/producten/' : `/producten/${p}/`}
						class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
					>
						{p}
					</a>
				)
			)}
			{page.url.next ? (
				<a
					href={page.url.next}
					class="rounded border border-gray-300 bg-white px-3 py-2 font-semibold text-navy-700 no-underline hover:border-navy-700"
				>
					Volgende →
				</a>
			) : (
				<span class="rounded border border-gray-200 bg-gray-50 px-3 py-2 font-semibold text-gray-400">
					Volgende →
				</span>
			)}
		</nav>
	</section>
</BaseLayout>
