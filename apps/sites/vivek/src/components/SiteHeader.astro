---
import { TENANT } from '../consts';

const pathname = Astro.url.pathname;

const headerMenu = TENANT.navMenus.find((m) => m.location === 'header');

// Fallback to the original hardcoded nav when Payload hasn't populated a
// menu yet — keeps the site usable on first dev boot.
const fallbackLinks = [
	{ href: '/reviews/', label: 'Reviews' },
	{ href: '/producten/', label: 'Producten' },
	{ href: '/keukenzaken/', label: 'Keukenzaken' },
	{ href: '/blog/', label: 'Blog' },
	{ href: '/contact/', label: 'Contact' },
];

const links = headerMenu?.items.length
	? headerMenu.items.map((i) => ({ href: i.href, label: i.label }))
	: fallbackLinks;

const isActive = (href: string) =>
	pathname === href || (href !== '/' && pathname.startsWith(href));
---

<header
	id="site-header"
	class="sticky top-0 z-40 border-b border-gray-200 bg-white transition-shadow"
>
	<div class="mx-auto flex min-h-[60px] max-w-6xl items-center justify-between px-4 py-4">
		<a
			href="/"
			class="text-xl font-bold text-navy-700 no-underline hover:text-navy-700"
			aria-label={`${TENANT.name} — home`}
		>
			{TENANT.logo ? (
				<img src={TENANT.logo} alt={TENANT.name} class="h-8 w-auto" />
			) : (
				TENANT.name
			)}
		</a>

		<nav aria-label="Hoofdnavigatie" class="hidden md:block">
			<ul class="flex items-center gap-7">
				{links.map((link) => (
					<li>
						<a
							href={link.href}
							aria-current={isActive(link.href) ? 'page' : undefined}
							class={`no-underline underline-offset-4 transition-colors ${
								isActive(link.href)
									? 'text-coral-600 underline'
									: 'text-gray-900 hover:text-coral-600 hover:underline'
							}`}
						>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<button
			id="menu-toggle"
			type="button"
			class="inline-flex items-center justify-center rounded p-2 text-navy-900 hover:bg-gray-100 md:hidden"
			aria-label="Menu openen"
			aria-controls="mobile-menu"
			aria-expanded="false"
		>
			<svg
				class="h-6 w-6"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				viewBox="0 0 24 24"
				aria-hidden="true"
			>
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>
	</div>

	<div id="mobile-menu" class="hidden border-t border-gray-200 bg-white md:hidden">
		<nav aria-label="Mobiele navigatie">
			<ul class="flex flex-col gap-1 px-4 py-3">
				{links.map((link) => (
					<li>
						<a
							href={link.href}
							aria-current={isActive(link.href) ? 'page' : undefined}
							class={`block py-2 no-underline ${
								isActive(link.href)
									? 'text-coral-600'
									: 'text-gray-900 hover:text-coral-600'
							}`}
						>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const setShadow = () => {
		if (!header) return;
		header.classList.toggle('shadow-md', window.scrollY > 8);
	};
	window.addEventListener('scroll', setShadow, { passive: true });
	setShadow();

	const btn = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => {
		const expanded = btn.getAttribute('aria-expanded') === 'true';
		btn.setAttribute('aria-expanded', String(!expanded));
		btn.setAttribute('aria-label', expanded ? 'Menu openen' : 'Menu sluiten');
		menu?.classList.toggle('hidden');
	});
</script>
