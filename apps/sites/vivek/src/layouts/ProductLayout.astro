---
import BaseLayout from './BaseLayout.astro';

interface Props {
	data: {
		title: string;
		meta_description: string | null;
		last_updated: string | null;
		product: {
			category: string | null;
			name: string | null;
			intro: string | null;
			rating: number | null;
			rating_out_of: number | null;
			image_url: string | null;
			affiliate_url: string | null;
			affiliate_network: string | null;
			affiliate_cta: string | null;
			specs: Array<{ label: string; value: string }>;
			description: string | null;
			pros: string[];
			cons: string[];
		};
	};
}

const { data } = Astro.props;
const { title, meta_description, last_updated, product } = data;

const productName = product.name ?? title;
const fullRating = 5;
const rating = product.rating ?? 0;
const ratingOutOf = product.rating_out_of ?? fullRating;
const ctaLabel = product.affiliate_cta ?? 'Bekijk de prijs';
const networkLabel =
	product.affiliate_network === 'awin'
		? 'Prijs via Coolblue'
		: product.affiliate_network === 'bol'
		? 'Prijs via bol.com'
		: null;

const hasSpecs = product.specs.length > 0;
const hasProsCons = product.pros.length > 0 || product.cons.length > 0;
const hasDescription = !!product.description;

const jsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Product',
	name: productName,
	description: meta_description ?? product.intro ?? title,
	...(product.image_url ? { image: product.image_url } : {}),
	...(product.category ? { brand: { '@type': 'Brand', name: product.category } } : {}),
};
if (rating > 0) {
	jsonLd.aggregateRating = {
		'@type': 'AggregateRating',
		ratingValue: rating,
		bestRating: ratingOutOf,
		reviewCount: 1,
	};
}
if (product.affiliate_url) {
	jsonLd.offers = {
		'@type': 'Offer',
		url: product.affiliate_url,
		priceCurrency: 'EUR',
		availability: 'https://schema.org/InStock',
	};
}
---

<BaseLayout
	title={title}
	description={meta_description ?? title}
	ogImage={product.image_url ?? undefined}
	ogType="product"
	preloadImage={product.image_url ?? undefined}
	jsonLd={jsonLd}
>
	<article>
		<!-- HERO -->
		<section class="mx-auto max-w-5xl px-4 pb-8 pt-12 md:pt-16">
			<div class="grid gap-8 md:grid-cols-2 md:items-start">
				<div class="flex items-center justify-center">
					{product.image_url ? (
						<img
							src={product.image_url}
							alt={productName}
							width="400"
							height="400"
							loading="eager"
							fetchpriority="high"
							decoding="async"
							class="max-h-96 w-full max-w-md rounded-lg bg-white object-contain shadow-sm"
						/>
					) : (
						<div class="flex aspect-square w-full max-w-md items-center justify-center rounded-lg bg-gradient-to-br from-navy-700 to-navy-900 text-white">
							Geen afbeelding
						</div>
					)}
				</div>

				<div>
					{product.category && (
						<p class="text-xs font-semibold uppercase tracking-wide text-gray-500">
							{product.category}
						</p>
					)}
					<h1 class="mt-2 text-3xl font-bold leading-tight tracking-tight text-navy-700 md:text-4xl">
						{productName}
					</h1>

					{rating > 0 && (
						<div class="mt-3 flex items-center gap-2" aria-label={`Waardering ${rating} van ${ratingOutOf}`}>
							<div class="flex items-center" role="img" aria-hidden="true">
								{Array.from({ length: fullRating }).map((_, i) => {
									const filled = i < rating;
									return (
										<svg
											class={`h-5 w-5 ${filled ? 'fill-coral-600' : 'fill-none stroke-coral-300'}`}
											viewBox="0 0 20 20"
											stroke-width="1.5"
										>
											<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.916c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.364 1.118l1.519 4.674c.3.922-.755 1.688-1.54 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.784.57-1.838-.196-1.539-1.118l1.519-4.674a1 1 0 00-.364-1.118L2.098 10.1c-.783-.57-.38-1.81.588-1.81h4.915a1 1 0 00.951-.69l1.519-4.674z" />
										</svg>
									);
								})}
							</div>
							<span class="text-sm text-gray-500">Waardering {rating}/{ratingOutOf}</span>
						</div>
					)}

					{product.intro && (
						<p class="mt-5 text-base leading-relaxed text-gray-900">
							{product.intro}
						</p>
					)}

					{product.affiliate_url && (
						<div class="mt-6">
							<a
								class="btn"
								href={product.affiliate_url}
								target="_blank"
								rel="noopener sponsored"
							>
								{ctaLabel}
							</a>
							{networkLabel && (
								<p class="mt-2 text-sm text-gray-500">{networkLabel}</p>
							)}
						</div>
					)}

					{last_updated && (
						<p class="mt-4 text-xs text-gray-500">
							Laatst bijgewerkt: {last_updated}
						</p>
					)}
				</div>
			</div>
		</section>

		<!-- SPECS -->
		{hasSpecs && (
			<section class="mx-auto max-w-5xl px-4 pb-10">
				<h2 class="text-2xl font-bold text-navy-700 md:text-3xl">
					Specificaties
				</h2>
				<dl class="mt-4 grid grid-cols-1 gap-x-8 gap-y-3 rounded-lg bg-gray-100 p-6 sm:grid-cols-2 md:grid-cols-3">
					{product.specs.map((s) => (
						<div class="flex flex-col">
							<dt class="text-sm font-semibold text-gray-600">{s.label}</dt>
							<dd class="text-base text-gray-900">{s.value}</dd>
						</div>
					))}
				</dl>
			</section>
		)}

		<!-- DESCRIPTION -->
		{hasDescription && (
			<section class="mx-auto max-w-3xl px-4 pb-10">
				<h2 class="text-2xl font-bold text-navy-700 md:text-3xl">
					Omschrijving van de {productName}
				</h2>
				<div
					class="prose prose-lg mx-auto mt-4"
					set:html={product.description}
				/>
			</section>
		)}

		<!-- PROS / CONS -->
		{hasProsCons && (
			<section class="mx-auto max-w-5xl px-4 pb-10">
				<div class="grid gap-4 md:grid-cols-2">
					{product.pros.length > 0 && (
						<div class="rounded-lg border border-gray-200 bg-white p-6">
							<h3 class="text-lg font-bold text-navy-700">Pluspunten</h3>
							<ul class="mt-3 space-y-2 text-gray-900">
								{product.pros.map((p) => (
									<li class="flex gap-2">
										<svg class="mt-1 h-5 w-5 flex-shrink-0 fill-none stroke-green-600" viewBox="0 0 20 20" stroke-width="2.5" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M5 10.5l3 3 7-7" />
										</svg>
										<span>{p}</span>
									</li>
								))}
							</ul>
						</div>
					)}
					{product.cons.length > 0 && (
						<div class="rounded-lg border border-gray-200 bg-white p-6">
							<h3 class="text-lg font-bold text-navy-700">Minpunten</h3>
							<ul class="mt-3 space-y-2 text-gray-900">
								{product.cons.map((c) => (
									<li class="flex gap-2">
										<svg class="mt-1 h-5 w-5 flex-shrink-0 fill-none stroke-red-600" viewBox="0 0 20 20" stroke-width="2.5" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M6 6l8 8M14 6l-8 8" />
										</svg>
										<span>{c}</span>
									</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</section>
		)}

		<!-- SECONDARY CTA -->
		{product.affiliate_url && (
			<section class="mx-auto max-w-3xl px-4 pb-16 text-center">
				<a
					class="btn"
					href={product.affiliate_url}
					target="_blank"
					rel="noopener sponsored"
				>
					{ctaLabel}
				</a>
				{networkLabel && (
					<p class="mt-2 text-sm text-gray-500">{networkLabel}</p>
				)}
			</section>
		)}

		<footer class="mx-auto max-w-3xl px-4 pb-16 text-xs text-gray-500">
			Dit artikel bevat affiliate-links. Als je iets koopt via een link,
			ontvangen wij een kleine commissie.
		</footer>
	</article>
</BaseLayout>
